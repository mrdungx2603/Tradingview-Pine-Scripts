//@version=6
// ─── SMC Market Structure Indicator — Phân tích cấu trúc thị trường theo Smart Money Concepts ───
// Tác giả: TV Pine
// Ngày tạo: 2026-06-18
// Phiên bản: 1.9
// Mô tả: Phát hiện cấu trúc xu hướng (HH/HL, LL/LH), Break of Structure (BoS),
//        Change of Character (CHoCH), Fair Value Gaps (FVG), Opening Gaps (OG),
//        Volume Imbalance (VI), Order Blocks (OB), Dashboard thống kê đầy đủ.
// Credits: Imbalance Detector logic adapted from LuxAlgo (CC BY-NC-SA 4.0)
indicator(
    title="SMC Market Structure Indicator",
    shorttitle="SMC_STRUCTURE",
    overlay=true,
    max_lines_count=500,
    max_labels_count=500,
    max_boxes_count=500
)

// ╔══════════════════════════════════════════╗
// ║              INPUTS                      ║
// ╚══════════════════════════════════════════╝

// ─── Seed Mode ───
seedMode = input.string(
    "Pivot Seed",
    "Seed Mode",
    options=["Pivot Seed", "Session Seed"],
    group="Tham Số Chính"
)

// ─── Pivot ───
pivotLength = input.int(
    5,
    "Pivot Length (cho Pivot Seed)",
    minval=2,
    maxval=50,
    group="Tham Số Chính"
)

// ─── BoS (Break of Structure) ───
show_bos      = input.bool(true, "Hiển Thị",                      group="BoS")
bos_title     = input.string("BoS", "Tiêu Đề Label",              group="BoS")
bos_style     = input.string("Solid", "Kiểu Đường BoS",
    options=["Solid", "Dashed", "Dotted"],                        group="Style")
bos_bull_color = input.color(color.blue,  "Màu BoS Tăng",         group="Style")
bos_bear_color = input.color(color.red,   "Màu BoS Giảm",         group="Style")

// ─── CHoCH (Change of Character) ───
show_choch   = input.bool(true, "Hiển Thị",                         group="CHoCH")
choch_title  = input.string("CHoCH", "Tiêu Đề Label",               group="CHoCH")
choch_style  = input.string("Dashed", "Kiểu Đường CHoCH",
    options=["Solid", "Dashed", "Dotted"],                          group="Style")
choch_color  = input.color(color.orange, "Màu CHoCH",               group="Style")

// ─── Label Cấu Trúc (HH/HL/LL/LH) ───
show_struct_labels = input.bool(true, "Hiển Thị",                  group="Label Cấu Trúc")
bullColor = input.color(color.blue,  "Màu Label Bull (HH/HL)",     group="Style")
bearColor = input.color(color.red,   "Màu Label Bear (LL/LH)",     group="Style")
show_temp_pivot = input.bool(true, "Hiển Thị Pivot Tạm (HL?/LH?)", group="Label Cấu Trúc")

// ─── Dashboard ───
show_dashboard = input.bool(true, "Hiển Thị",                      group="Dashboard")
dashboard_pos = input.string("Top Right", "Vị Trí",
    options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"],
    group="Dashboard")

// ─── Fair Value Gaps (FVG) ───
show_fvg          = input.bool(true, "Hiển Thị",                      group="FVG")
bull_fvg_color    = input.color(#2157f3, "Màu FVG Tăng",              group="Style")
bear_fvg_color    = input.color(#ff1100, "Màu FVG Giảm",              group="Style")
fvg_extend        = input.int(0, "Kéo Dài FVG (bars)", minval=0,     group="FVG")

// ─── Opening Gaps (OG) ───
show_og           = input.bool(true, "Hiển Thị",                      group="OG")
bull_og_color     = input.color(#2157f3, "Màu OG Tăng",               group="Style")
bear_og_color     = input.color(#ff1100, "Màu OG Giảm",               group="Style")
og_extend         = input.int(0, "Kéo Dài OG (bars)", minval=0,      group="OG")

// ─── Volume Imbalance (VI) ───
show_vi           = input.bool(true, "Hiển Thị",                      group="VI")
bull_vi_color     = input.color(#2157f3, "Màu VI Tăng",               group="Style")
bear_vi_color     = input.color(#ff1100, "Màu VI Giảm",               group="Style")
vi_extend         = input.int(0, "Kéo Dài VI (bars)", minval=0,      group="VI")

// ─── Bộ Lọc Imbalance ───
imb_usewidth      = input.bool(false, "Lọc Theo Độ Rộng Tối Thiểu",  group="Bộ Lọc Imbalance")
imb_gapwidth      = input.float(0, "Độ Rộng Tối Thiểu",              group="Bộ Lọc Imbalance")
imb_width_method  = input.string("Points", "Đơn Vị",
    options=["Points", "%", "ATR"],                                   group="Bộ Lọc Imbalance")

// ─── Dashboard Imbalance ───
show_imb_dashboard   = input.bool(false, "Hiển Thị Dashboard",       group="Dashboard Imbalance")
imb_dashboard_pos    = input.string("Bottom Right", "Vị Trí",
    options=["Top Right", "Bottom Right", "Bottom Left"],            group="Dashboard Imbalance")
imb_text_size        = input.string("Tiny", "Kích Thước Chữ",
    options=["Tiny", "Small", "Normal"],                              group="Dashboard Imbalance")

// ─── Order Blocks (OB) ───
show_ob          = input.bool(true, "Hiển Thị OB",                  group="OB")
max_ob_active    = input.int(30, "Số OB Active Tối Đa", minval=0, maxval=100, group="OB")
ob_filter_mode   = input.string("All", "Bộ Lọc OB Đã Mitigated",
    options=["All", "Active", "Mitigated"],                          group="OB")
ob_bull_color    = input.color(#089981, "Màu OB Tăng (Demand)",      group="Style")
ob_bear_color    = input.color(#f23645, "Màu OB Giảm (Supply)",      group="Style")
ob_transparency  = input.int(70, "Độ Trong Suốt OB Active", minval=0, maxval=100, group="Style")
show_last_ob     = input.bool(true, "Hiển Thị OB Vừa Mitigated",     group="OB")


// ╔══════════════════════════════════════════╗
// ║        HÀM HELPER — CHUYỂN ĐỔI          ║
// ╚══════════════════════════════════════════╝

// ─── Chuyển đổi string → line style ───
get_line_style(string style_name) =>
    switch style_name
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

// ─── Chuyển đổi string → vị trí bảng ───
get_dashboard_pos(string pos_name) =>
    switch pos_name
        "Top Right"     => position.top_right
        "Top Left"      => position.top_left
        "Bottom Right"  => position.bottom_right
        "Bottom Left"   => position.bottom_left
        => position.top_right

// ╔══════════════════════════════════════════╗
// ║           BIẾN TRẠNG THÁI                ║
// ╚══════════════════════════════════════════╝

var int trend       = 0   // 1 = UPTREND, -1 = DOWNTREND, 0 = INIT
var int hh_bar      = na
var float hh_price  = na
var int hl_bar      = na
var float hl_price  = na
var int ll_bar      = na
var float ll_price  = na
var int lh_bar      = na
var float lh_price  = na

// Hệ thống candidate (săn điểm cực trị)
var int cand_bar    = na
var float cand_high = na
var float cand_low  = na
var int cand_type   = 0   // 1 = săn HH, -1 = săn LL, 0 = không hoạt động
var int trigger_bar = na  // Lưu bar index lúc xảy ra Breakout để quét range HL/LH

// ─── Biến alert cho CHoCH ───
var bool choch_bull_triggered = false
var bool choch_bear_triggered = false

// ─── Temp Pivot Label ───
var label temp_pivot_label = na

// Quản lý phiên
var bool seeded     = false
is_new_session      = timeframe.isminutes and session.isfirstbar_regular

// ╔══════════════════════════════════════════╗
// ║        ORDER BLOCK (OB) STATE            ║
// ╚══════════════════════════════════════════╝

// ─── UDT OrderBlock ───
type OrderBlock
    int    bar_origin       // bar index của candle gốc (origin)
    float  top              // giá high của candle origin
    float  bottom           // giá low của candle origin
    bool   is_bullish       // true = Demand OB (Tăng), false = Supply OB (Giảm)
    string source           // "FVG" | "OG" | "VI"
    bool   is_mitigated     // đã bị mitigation chưa
    int    bar_mitigation   // bar index lúc mitigation (na nếu chưa)

// ─── OB Pool & Counters ───
var array<OrderBlock> ob_list           = array.new<OrderBlock>()
var array<box>        ob_boxes          = array.new_box(0)
var int               ob_bull_count      = 0
var int               ob_bear_count      = 0
var int               ob_bull_mitigated  = 0
var int               ob_bear_mitigated  = 0
var int               last_mitigated_idx = na

// ╔══════════════════════════════════════════╗
// ║      TIMEFRAME CHECK & RESET             ║
// ╚══════════════════════════════════════════╝

if seedMode == "Session Seed" and not timeframe.isminutes
    runtime.error("Session Seed chỉ áp dụng cho khung thời gian phút (< 1 giờ)!")

if seedMode == "Session Seed" and is_new_session
    trend     := 0
    seeded    := false
    hh_bar    := na
    hh_price  := na
    hl_bar    := na
    hl_price  := na
    ll_bar    := na
    ll_price  := na
    lh_bar    := na
    lh_price  := na
    cand_type := 0
    cand_bar  := na

// ╔══════════════════════════════════════════╗
// ║           SEEDING LOGIC                  ║
// ╚══════════════════════════════════════════╝

if not seeded
    if seedMode == "Pivot Seed"
        ph = ta.pivothigh(pivotLength, pivotLength)
        pl = ta.pivotlow(pivotLength, pivotLength)

        // Lưu trữ các pivot thực tế dựa trên offset
        var int last_ph_bar = na
        var float last_ph_val = na
        var int last_pl_bar = na
        var float last_pl_val = na

        if not na(ph)
            last_ph_bar := bar_index - pivotLength
            last_ph_val := ph
        if not na(pl)
            last_pl_bar := bar_index - pivotLength
            last_pl_val := pl

        if not na(last_ph_bar) and not na(last_pl_bar)
            if last_ph_bar > last_pl_bar
                // High xuất hiện sau Low → Uptrend
                trend    := 1
                hh_bar   := last_ph_bar
                hh_price := last_ph_val
                hl_bar   := last_pl_bar
                hl_price := last_pl_val
                seeded   := true
            else
                // Low xuất hiện sau High → Downtrend
                trend    := -1
                ll_bar   := last_pl_bar
                ll_price := last_pl_val
                lh_bar   := last_ph_bar
                lh_price := last_ph_val
                seeded   := true

    else if seedMode == "Session Seed"
        // Lấy bar đầu tiên của session làm tham chiếu, trend = 0 chờ breakout
        hh_bar   := bar_index
        hh_price := high
        hl_bar   := bar_index
        hl_price := low
        ll_bar   := bar_index
        ll_price := low
        lh_bar   := bar_index
        lh_price := high
        seeded   := true

// ╔══════════════════════════════════════════╗
// ║        HÀM HELPER — VẼ ĐỒ HỌA           ║
// ╚══════════════════════════════════════════╝

// Resolve kiểu đường — không dùng var để phản ứng khi user đổi input
line_style_bos   = get_line_style(bos_style)
line_style_choch = get_line_style(choch_style)

// ─── Vẽ Break of Structure (BoS) ───
plot_bos(int start_b, int end_b, float lvl, color col) =>
    if show_bos
        line.new(
            x1=start_b, y1=lvl,
            x2=end_b,   y2=lvl,
            xloc=xloc.bar_index,
            style=line_style_bos,
            color=col,
            width=1
        )
        label.new(
            x=math.round((start_b + end_b) / 2),
            y=lvl,
            text=bos_title,
            xloc=xloc.bar_index,
            textcolor=col,
            style=label.style_none,
            size=size.small
        )

// ─── Vẽ Change of Character (CHoCH) ───
plot_choch(int start_b, int end_b, float lvl, color col) =>
    if show_choch
        line.new(
            x1=start_b, y1=lvl,
            x2=end_b,   y2=lvl,
            xloc=xloc.bar_index,
            style=line_style_choch,
            color=col,
            width=1
        )
        label.new(
            x=math.round((start_b + end_b) / 2),
            y=lvl,
            text=choch_title,
            xloc=xloc.bar_index,
            textcolor=col,
            style=label.style_none,
            size=size.small
        )

// ─── Vẽ Label cho HH/HL/LL/LH ───
plot_label(int b_idx, string txt, color col, bool is_up) =>
    if show_struct_labels
        label.new(
            x=b_idx,
            y=is_up ? low[bar_index - b_idx] : high[bar_index - b_idx],
            text=txt,
            color=col,
            textcolor=color.white,
            style=is_up ? label.style_label_up : label.style_label_down,
            size=size.small
        )

// ╔══════════════════════════════════════════╗
// ║      HÀM HELPER — IMBALANCE (FVG/OG/VI)  ║
// ╚══════════════════════════════════════════╝

// ATR dùng cho bộ lọc độ rộng imbalance
float atr_val = ta.atr(200)

// ─── Phát hiện imbalance và đếm số lần xuất hiện ───
imbalance_detection(bool show, bool usewidth, string method, float width, float top, float btm, bool condition) =>
    var bool is_width = true
    var int  count    = 0

    if usewidth
        float dist = top - btm
        is_width := switch method
            "Points" => dist > width
            "%"      => dist / btm * 100 > width
            "ATR"    => dist > atr_val * width

    bool is_true = show and condition and is_width
    count += is_true ? 1 : 0

    [is_true, count]

// ─── Phát hiện Bullish Imbalance bị lấp (filled) ───
bull_filled(bool condition, float btm) =>
    var array<float> btms  = array.new_float(0)
    var int          count = 0

    if condition
        array.unshift(btms, btm)

    int size = array.size(btms)
    if size > 0
        for i = size - 1 to 0
            float value = array.get(btms, i)
            if low < value
                array.remove(btms, i)
                count += 1
    count

// ─── Phát hiện Bearish Imbalance bị lấp (filled) ───
bear_filled(bool condition, float top) =>
    var array<float> tops  = array.new_float(0)
    var int          count = 0

    if condition
        array.unshift(tops, top)

    int size = array.size(tops)
    if size > 0
        for i = size - 1 to 0
            float value = array.get(tops, i)
            if high > value
                array.remove(tops, i)
                count += 1
    count

// ─── Tìm cực trị trong range, loại trừ 1 bar ───
// find_high = true → tìm highest high, false → tìm lowest low
find_extreme_in_range(int start_bar, int end_bar, int exclude_bar, bool find_high) =>
    int   best_bar   = start_bar
    float best_price = find_high ? high[bar_index - start_bar] : low[bar_index - start_bar]
    for i = start_bar to end_bar
        if i != exclude_bar
            if find_high
                if high[bar_index - i] > best_price
                    best_price := high[bar_index - i]
                    best_bar   := i
            else
                if low[bar_index - i] < best_price
                    best_price := low[bar_index - i]
                    best_bar   := i
    [best_bar, best_price]

// ╔══════════════════════════════════════════╗
// ║     STATE MACHINE & CANDIDATE HUNTING    ║
// ╚══════════════════════════════════════════╝

if seeded

    // ─── CASE 0: KHỞI TẠO TỪ SESSION SEED (Chưa rõ Trend) ───
    if trend == 0
        if close > hh_price
            cand_type   := 1
            cand_bar    := bar_index
            cand_high   := high
            trigger_bar := bar_index
            plot_bos(hh_bar, bar_index, hh_price, bos_bull_color)
            trend       := 1
        else if close < ll_price
            cand_type   := -1
            cand_bar    := bar_index
            cand_low    := low
            trigger_bar := bar_index
            plot_bos(ll_bar, bar_index, ll_price, bos_bear_color)
            trend       := -1

    // ─── CASE 1: UPTREND ───
    else if trend == 1

        if cand_type == 0
            if close > hh_price
                cand_type   := 1
                cand_bar    := bar_index
                cand_high   := high
                trigger_bar := hh_bar
                plot_bos(hh_bar, bar_index, hh_price, bos_bull_color)
            else if close < hl_price
                cand_type   := -1
                cand_bar    := bar_index
                cand_low    := low
                trigger_bar := hl_bar
                plot_choch(hl_bar, bar_index, hl_price, choch_color)
                choch_bear_triggered := true

        else if cand_type == 1
            // Đang săn NEW_HH
            if high > cand_high
                cand_bar  := bar_index
                cand_high := high
            else if close < low[bar_index - cand_bar]
                // XÁC NHẬN NEW HH
                int new_hh_bar = cand_bar
                float new_hh_price = cand_high
                plot_label(new_hh_bar, "HH", bullColor, false)

                // Quét Range tìm New HL (Thấp nhất từ HH cũ → HH mới, loại trừ chính HH)
                [lowest_b, lowest_l] = find_extreme_in_range(trigger_bar, new_hh_bar, new_hh_bar, false)

                hl_bar   := lowest_b
                hl_price := lowest_l
                plot_label(hl_bar, "HL", bullColor, true)

                hh_bar    := new_hh_bar
                hh_price  := new_hh_price
                cand_type := 0

        else if cand_type == -1
            // Đang săn Đảo chiều sang Downtrend (CHoCH)
            if low < cand_low
                cand_bar := bar_index
                cand_low := low
            else if close > high[bar_index - cand_bar]
                // XÁC NHẬN NEW LL + CHUYỂN XU HƯỚNG
                int new_ll_bar = cand_bar
                float new_ll_price = cand_low
                plot_label(new_ll_bar, "LL", bearColor, true)

                // Quét Range tìm New LH (Cao nhất từ HL cũ → LL mới, loại trừ chính LL)
                [highest_b, highest_h] = find_extreme_in_range(trigger_bar, new_ll_bar, new_ll_bar, true)

                lh_bar    := highest_b
                lh_price  := highest_h
                plot_label(lh_bar, "LH", bearColor, false)

                ll_bar    := new_ll_bar
                ll_price  := new_ll_price
                trend     := -1
                cand_type := 0

    // ─── CASE -1: DOWNTREND ───
    else if trend == -1

        if cand_type == 0
            if close < ll_price
                cand_type   := -1
                cand_bar    := bar_index
                cand_low    := low
                trigger_bar := ll_bar
                plot_bos(ll_bar, bar_index, ll_price, bos_bear_color)
            else if close > lh_price
                cand_type   := 1
                cand_bar    := bar_index
                cand_high   := high
                trigger_bar := lh_bar
                plot_choch(lh_bar, bar_index, lh_price, choch_color)
                choch_bull_triggered := true

        else if cand_type == -1
            // Đang săn NEW_LL
            if low < cand_low
                cand_bar := bar_index
                cand_low := low
            else if close > high[bar_index - cand_bar]
                // XÁC NHẬN NEW LL
                int new_ll_bar = cand_bar
                float new_ll_price = cand_low
                plot_label(new_ll_bar, "LL", bearColor, true)

                // Quét Range tìm New LH (Cao nhất từ LL cũ → LL mới, loại trừ chính LL)
                [highest_b, highest_h] = find_extreme_in_range(trigger_bar, new_ll_bar, new_ll_bar, true)

                lh_bar    := highest_b
                lh_price  := highest_h
                plot_label(lh_bar, "LH", bearColor, false)

                ll_bar    := new_ll_bar
                ll_price  := new_ll_price
                cand_type := 0

        else if cand_type == 1
            // Đang săn Đảo chiều sang Uptrend (CHoCH)
            if high > cand_high
                cand_bar  := bar_index
                cand_high := high
            else if close < low[bar_index - cand_bar]
                // XÁC NHẬN NEW HH + CHUYỂN XU HƯỚNG
                int new_hh_bar = cand_bar
                float new_hh_price = cand_high
                plot_label(new_hh_bar, "HH", bullColor, false)

                // Quét Range tìm New HL (Thấp nhất từ LH cũ → HH mới, loại trừ chính HH)
                [lowest_b, lowest_l] = find_extreme_in_range(trigger_bar, new_hh_bar, new_hh_bar, false)

                hl_bar    := lowest_b
                hl_price  := lowest_l
                plot_label(hl_bar, "HL", bullColor, true)

                hh_bar    := new_hh_bar
                hh_price  := new_hh_price
                trend     := 1
                cand_type := 0

// ╔══════════════════════════════════════════╗
// ║     TEMP PIVOT — HIỂN THỊ PIVOT TẠM THỜI ║
// ╚══════════════════════════════════════════╝

// Xóa temp label cũ mỗi bar để vẽ lại
if not na(temp_pivot_label)
    label.delete(temp_pivot_label)
    temp_pivot_label := na

// Vẽ temp pivot nếu đang trong quá trình săn (cand_type != 0)
if show_temp_pivot and show_struct_labels and cand_type != 0 and seeded
    // cand_type == 1  → đang săn đỉnh (HH) → temp pivot = đáy thấp nhất (HL?)
    // cand_type == -1 → đang săn đáy (LL) → temp pivot = đỉnh cao nhất  (LH?)
    bool is_hunting_high = (cand_type == 1)

    int    scan_start = trigger_bar
    int    scan_end   = cand_bar
    bool   found      = false
    float  best_price = na
    int    best_bar   = na

    if not na(scan_start) and not na(scan_end) and scan_start <= scan_end
        for i = scan_start to scan_end
            // Loại trừ chính cand_bar (bar cực trị đang săn)
            if i != scan_end
                if not found
                    best_price := is_hunting_high ? low[bar_index - i] : high[bar_index - i]
                    best_bar   := i
                    found      := true
                else
                    if is_hunting_high
                        if low[bar_index - i] < best_price
                            best_price := low[bar_index - i]
                            best_bar   := i
                    else
                        if high[bar_index - i] > best_price
                            best_price := high[bar_index - i]
                            best_bar   := i

        if found
            temp_pivot_label := label.new(
                x=best_bar,
                y=is_hunting_high ? low[bar_index - best_bar] : high[bar_index - best_bar],
                text=is_hunting_high ? "HL?" : "LH?",
                color=color.new(color.gray, 30),
                textcolor=color.gray,
                style=is_hunting_high ? label.style_label_up : label.style_label_down,
                size=size.tiny
            )

// ╔══════════════════════════════════════════╗
// ║   IMBALANCE DETECTION (FVG / OG / VI)   ║
// ╚══════════════════════════════════════════╝

// ─── Volume Imbalances (VI) ───
// Bullish VI
float bull_gap_top    = math.min(close, open)
float bull_gap_btm    = math.max(close[1], open[1])

[bull_vi, bull_vi_count] = imbalance_detection(
    show_vi, imb_usewidth, imb_width_method, imb_gapwidth,
    bull_gap_top, bull_gap_btm,
    open > close[1] and high[1] > low and close > close[1] and open > open[1] and high[1] < bull_gap_top)

bull_vi_filled = bull_filled(bull_vi[1], bull_gap_btm[1])

// Bearish VI
float bear_gap_top    = math.min(close[1], open[1])
float bear_gap_btm    = math.max(close, open)

[bear_vi, bear_vi_count] = imbalance_detection(
    show_vi, imb_usewidth, imb_width_method, imb_gapwidth,
    bear_gap_top, bear_gap_btm,
    open < close[1] and low[1] < high and close < close[1] and open < open[1] and low[1] > bear_gap_btm)

bear_vi_filled = bear_filled(bear_vi[1], bear_gap_top[1])

if bull_vi
    box.new(bar_index - 1, bull_gap_top, bar_index + vi_extend, bull_gap_btm,
        border_color=bull_vi_color, bgcolor=na, border_style=line.style_dotted)

if bear_vi
    box.new(bar_index - 1, bear_gap_top, bar_index + vi_extend, bear_gap_btm,
        border_color=bear_vi_color, bgcolor=na, border_style=line.style_dotted)

// ─── OB từ VI ───
if show_ob and (bull_vi or bear_vi)
    // FIFO: xóa OB cũ nhất nếu vượt giới hạn
    if max_ob_active > 0 and array.size(ob_list) >= max_ob_active
        OrderBlock oldest = array.shift(ob_list)
        if array.size(ob_boxes) > 0
            box dead = array.shift(ob_boxes)
            box.delete(dead)
        // Điều chỉnh last_mitigated_idx sau khi shift
        if not na(last_mitigated_idx)
            if last_mitigated_idx == 0
                last_mitigated_idx := na
            else
                last_mitigated_idx := last_mitigated_idx - 1

    if bull_vi
        int    origin_bar  = bar_index - 1
        float  origin_high = high[1]
        float  origin_low  = low[1]
        OrderBlock new_ob = OrderBlock.new(origin_bar, origin_high, origin_low, true, "VI", false, na)
        array.push(ob_list, new_ob)
        ob_bull_count += 1

        box b = box.new(origin_bar, origin_high, bar_index + 1, origin_low,
            border_color=ob_bull_color, bgcolor=color.new(ob_bull_color, ob_transparency),
            border_style=line.style_dashed)
        array.push(ob_boxes, b)

    if bear_vi
        int    origin_bar  = bar_index - 1
        float  origin_high = high[1]
        float  origin_low  = low[1]
        OrderBlock new_ob = OrderBlock.new(origin_bar, origin_high, origin_low, false, "VI", false, na)
        array.push(ob_list, new_ob)
        ob_bear_count += 1

        box b = box.new(origin_bar, origin_high, bar_index + 1, origin_low,
            border_color=ob_bear_color, bgcolor=color.new(ob_bear_color, ob_transparency),
            border_style=line.style_dashed)
        array.push(ob_boxes, b)

// ─── Opening Gaps (OG) ───
// Bullish OG
[bull_og, bull_og_count] = imbalance_detection(
    show_og, imb_usewidth, imb_width_method, imb_gapwidth,
    bull_gap_top, bull_gap_btm,
    low > high[1])

bull_og_filled = bull_filled(bull_og, bull_gap_btm)

// Bearish OG
[bear_og, bear_og_count] = imbalance_detection(
    show_og, imb_usewidth, imb_width_method, imb_gapwidth,
    bear_gap_top, bear_gap_btm,
    high < low[1])

bear_og_filled = bear_filled(bear_og, bear_gap_top)

if bull_og
    box.new(bar_index - 1, bull_gap_top, bar_index + og_extend, bull_gap_btm,
        border_color=na, bgcolor=color.new(bull_og_color, 50),
        text="OG", text_color=color.white)

if bear_og
    box.new(bar_index - 1, bear_gap_top, bar_index + og_extend, bear_gap_btm,
        border_color=na, bgcolor=color.new(bear_og_color, 50),
        text="OG", text_color=color.white)

// ─── OB từ OG ───
if show_ob and (bull_og or bear_og)
    if max_ob_active > 0 and array.size(ob_list) >= max_ob_active
        OrderBlock oldest = array.shift(ob_list)
        if array.size(ob_boxes) > 0
            box dead = array.shift(ob_boxes)
            box.delete(dead)
        // Điều chỉnh last_mitigated_idx sau khi shift
        if not na(last_mitigated_idx)
            if last_mitigated_idx == 0
                last_mitigated_idx := na
            else
                last_mitigated_idx := last_mitigated_idx - 1

    if bull_og
        int    origin_bar  = bar_index - 1
        float  origin_high = high[1]
        float  origin_low  = low[1]
        OrderBlock new_ob = OrderBlock.new(origin_bar, origin_high, origin_low, true, "OG", false, na)
        array.push(ob_list, new_ob)
        ob_bull_count += 1

        box b = box.new(origin_bar, origin_high, bar_index + 1, origin_low,
            border_color=ob_bull_color, bgcolor=color.new(ob_bull_color, ob_transparency),
            border_style=line.style_dashed)
        array.push(ob_boxes, b)

    if bear_og
        int    origin_bar  = bar_index - 1
        float  origin_high = high[1]
        float  origin_low  = low[1]
        OrderBlock new_ob = OrderBlock.new(origin_bar, origin_high, origin_low, false, "OG", false, na)
        array.push(ob_list, new_ob)
        ob_bear_count += 1

        box b = box.new(origin_bar, origin_high, bar_index + 1, origin_low,
            border_color=ob_bear_color, bgcolor=color.new(ob_bear_color, ob_transparency),
            border_style=line.style_dashed)
        array.push(ob_boxes, b)

// ─── Fair Value Gaps (FVG) ───
// Bullish FVG
[bull_fvg, bull_fvg_count] = imbalance_detection(
    show_fvg, imb_usewidth, imb_width_method, imb_gapwidth,
    low, high[2],
    low > high[2] and close[1] > high[2] and not (bull_og or bull_og[1]))

bull_fvg_filled = bull_filled(bull_fvg, high[2])

// Bearish FVG
[bear_fvg, bear_fvg_count] = imbalance_detection(
    show_fvg, imb_usewidth, imb_width_method, imb_gapwidth,
    low[2], high,
    high < low[2] and close[1] < low[2] and not (bear_og or bear_og[1]))

bear_fvg_filled = bear_filled(bear_fvg, low[2])

if bull_fvg
    float bull_fvg_avg = math.avg(low, high[2])
    box.new(bar_index - 2, low, bar_index + fvg_extend, high[2],
        border_color=na, bgcolor=color.new(bull_fvg_color, 80))
    line.new(bar_index - 2, bull_fvg_avg, bar_index + fvg_extend, bull_fvg_avg,
        color=bull_fvg_color)

if bear_fvg
    float bear_fvg_avg = math.avg(low[2], high)
    box.new(bar_index - 2, low[2], bar_index + fvg_extend, high,
        border_color=na, bgcolor=color.new(bear_fvg_color, 80))
    line.new(bar_index - 2, bear_fvg_avg, bar_index + fvg_extend, bear_fvg_avg,
        color=bear_fvg_color)

// ─── OB từ FVG ───
if show_ob and (bull_fvg or bear_fvg)
    if max_ob_active > 0 and array.size(ob_list) >= max_ob_active
        OrderBlock oldest = array.shift(ob_list)
        if array.size(ob_boxes) > 0
            box dead = array.shift(ob_boxes)
            box.delete(dead)
        // Điều chỉnh last_mitigated_idx sau khi shift
        if not na(last_mitigated_idx)
            if last_mitigated_idx == 0
                last_mitigated_idx := na
            else
                last_mitigated_idx := last_mitigated_idx - 1

    if bull_fvg
        int    origin_bar  = bar_index - 2
        float  origin_high = high[2]
        float  origin_low  = low[2]
        OrderBlock new_ob = OrderBlock.new(origin_bar, origin_high, origin_low, true, "FVG", false, na)
        array.push(ob_list, new_ob)
        ob_bull_count += 1

        box b = box.new(origin_bar, origin_high, bar_index + 1, origin_low,
            border_color=ob_bull_color, bgcolor=color.new(ob_bull_color, ob_transparency),
            border_style=line.style_dashed)
        array.push(ob_boxes, b)

    if bear_fvg
        int    origin_bar  = bar_index - 2
        float  origin_high = high[2]
        float  origin_low  = low[2]
        OrderBlock new_ob = OrderBlock.new(origin_bar, origin_high, origin_low, false, "FVG", false, na)
        array.push(ob_list, new_ob)
        ob_bear_count += 1

        box b = box.new(origin_bar, origin_high, bar_index + 1, origin_low,
            border_color=ob_bear_color, bgcolor=color.new(ob_bear_color, ob_transparency),
            border_style=line.style_dashed)
        array.push(ob_boxes, b)

// ─── OB Mitigation Check + Bộ Lọc Hiển Thị ───
if show_ob
    int ob_size = array.size(ob_list)
    if ob_size > 0
        for i = ob_size - 1 to 0
            OrderBlock ob_chk   = array.get(ob_list, i)
            bool       is_bull  = ob_chk.is_bullish
            bool       is_mit   = ob_chk.is_mitigated
            if not is_mit
                bool triggered = is_bull ? (low <= ob_chk.top) : (high >= ob_chk.bottom)
                if triggered
                    ob_chk.is_mitigated   := true
                    ob_chk.bar_mitigation := bar_index
                    array.set(ob_list, i, ob_chk)
                    last_mitigated_idx := i
                    if is_bull
                        ob_bull_mitigated += 1
                    else
                        ob_bear_mitigated += 1

                    // Cập nhật box: đóng tại mitigation bar, đổi style
                    if i < array.size(ob_boxes)
                        box b_mit = array.get(ob_boxes, i)
                        box.set_right(b_mit, bar_index)
                        box.set_border_style(b_mit, line.style_solid)
                        box.set_bgcolor(b_mit, color.new(
                            is_bull ? ob_bull_color : ob_bear_color,
                            math.min(ob_transparency + 15, 100)))

    // Kéo dài box active đến bar hiện tại
    if array.size(ob_boxes) > 0 and array.size(ob_list) > 0
        int box_ct = math.min(array.size(ob_list), array.size(ob_boxes))
        for i = 0 to box_ct - 1
            OrderBlock ob_ext = array.get(ob_list, i)
            if not ob_ext.is_mitigated
                box b_ext = array.get(ob_boxes, i)
                box.set_right(b_ext, bar_index + 1)

    // Bộ lọc hiển thị OB theo ob_filter_mode
    bool show_active_ob    = ob_filter_mode == "All" or ob_filter_mode == "Active"
    bool show_mitigated_ob = ob_filter_mode == "All" or ob_filter_mode == "Mitigated"

    if array.size(ob_boxes) > 0 and array.size(ob_list) > 0
        int box_ct2 = math.min(array.size(ob_list), array.size(ob_boxes))
        for i = 0 to box_ct2 - 1
            OrderBlock ob_f = array.get(ob_list, i)
            box        b_f  = array.get(ob_boxes, i)
            bool       is_bull_f = ob_f.is_bullish
            color      border_c  = is_bull_f ? ob_bull_color : ob_bear_color
            color      bg_c      = is_bull_f ? ob_bull_color : ob_bear_color
            bool       is_last_mitigated = (i == last_mitigated_idx)

            if ob_f.is_mitigated
                if show_mitigated_ob and (show_last_ob or not is_last_mitigated)
                    box.set_border_color(b_f, border_c)
                    box.set_bgcolor(b_f, color.new(bg_c, math.min(ob_transparency + 15, 100)))
                else
                    box.set_border_color(b_f, na)
                    box.set_bgcolor(b_f, na)
            else
                if show_active_ob
                    box.set_border_color(b_f, border_c)
                    box.set_bgcolor(b_f, color.new(bg_c, ob_transparency))
                else
                    box.set_border_color(b_f, na)
                    box.set_bgcolor(b_f, na)

// ╔══════════════════════════════════════════╗
// ║     BẢNG THỐNG KÊ CẤU TRÚC SMC          ║
// ╚══════════════════════════════════════════╝

var table smc_table = table.new(
    get_dashboard_pos(dashboard_pos),
    columns=2,
    rows=4,
    bgcolor=#1e222d,
    border_width=1,
    border_color=#5b5f6b
)

if show_dashboard and barstate.islast
    // Xác định biên Swing hiện tại
    float swing_high = (trend == 1) ? hh_price : lh_price
    float swing_low  = (trend == 1) ? hl_price : ll_price

    // Tính toán % vị trí giá hiện tại (Premium/Discount)
    // Bull: 100 - giá trị gốc → % cao = Discount (gần Swing Low), % thấp = Premium (gần Swing High)
    // Bear: giữ nguyên → % thấp = Discount (gần Swing Low), % cao = Premium (gần Swing High)
    float range_diff = swing_high - swing_low
    float pos_pct_raw = (range_diff != 0) ? ((close - swing_low) / range_diff) * 100 : 0
    float pos_pct = (trend == 1) ? (100 - pos_pct_raw) : pos_pct_raw

    // Nội dung hiển thị
    string row1_col1 = (trend == 1) ? "HH Price" : "LH Price"
    string row1_col2 = str.tostring(
        (trend == 1) ? hh_price : lh_price,
        format.mintick
    )

    string row2_col1 = (trend == 1) ? "HL Price" : "LL Price"
    string row2_col2 = str.tostring(
        (trend == 1) ? hl_price : ll_price,
        format.mintick
    )

    string row3_col1 = "Vị trí trong Swing"
    string row3_col2 = str.tostring(pos_pct, "#.##") + "%"

    // Fill bảng
    table.cell(smc_table, 0, 0, "THÔNG SỐ SMC",
        text_color=color.white, text_size=size.small, bgcolor=#3d4252)
    table.cell(smc_table, 1, 0, (trend == 1 ? "BULLISH" : "BEARISH"),
        text_color=color.white, text_size=size.small,
        bgcolor=(trend == 1 ? bullColor : bearColor))

    table.cell(smc_table, 0, 1, row1_col1,
        text_color=color.white, text_size=size.small)
    table.cell(smc_table, 1, 1, row1_col2,
        text_color=color.white, text_size=size.small)

    table.cell(smc_table, 0, 2, row2_col1,
        text_color=color.white, text_size=size.small)
    table.cell(smc_table, 1, 2, row2_col2,
        text_color=color.white, text_size=size.small)

    // Màu sắc: Bull → % cao = Discount (xanh), % thấp = Premium (đỏ)
    //          Bear → % cao = Premium (đỏ), % thấp = Discount (xanh)
    color pos_color = (trend == 1) ? (pos_pct > 50 ? color.green : color.red)
                                  : (pos_pct > 50 ? color.red   : color.green)

    table.cell(smc_table, 0, 3, row3_col1,
        text_color=color.white, text_size=size.small)
    table.cell(smc_table, 1, 3, row3_col2,
        text_color=pos_color,
        text_size=size.small)

// ╔══════════════════════════════════════════╗
// ║   BẢNG THỐNG KÊ IMBALANCE (FVG/OG/VI)   ║
// ╚══════════════════════════════════════════╝

// ─── Chuyển đổi kích thước chữ ───
get_imb_text_size(string size_name) =>
    switch size_name
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        => size.tiny

// ─── Hàm điền dữ liệu vào bảng imbalance ───
set_imb_cells(table tb, int column, int bull_filled_val, int bull_count_val, int bear_filled_val, int bear_count_val, color bull_css, color bear_css, string size_str) =>
    string table_size = size_str
    string sz         = get_imb_text_size(table_size)

    table.cell(tb, column, 1, str.tostring(bull_count_val),
        text_color=bull_css, text_size=sz, text_halign=text.align_left)

    float bull_fill_pct = bull_count_val > 0 ? bull_filled_val / bull_count_val : 0.0
    table.cell(tb, column, 2, str.tostring(bull_fill_pct * 100, "#.##") + "%",
        text_color=bull_css, text_size=sz, text_halign=text.align_left)

    table.cell(tb, column, 3, str.tostring(bear_count_val),
        text_color=bear_css, text_size=sz, text_halign=text.align_left)

    float bear_fill_pct = bear_count_val > 0 ? bear_filled_val / bear_count_val : 0.0
    table.cell(tb, column, 4, str.tostring(bear_fill_pct * 100, "#.##") + "%",
        text_color=bear_css, text_size=sz, text_halign=text.align_left)

// ─── Khởi tạo bảng imbalance ───
var table imb_table = table.new(
    get_dashboard_pos(imb_dashboard_pos),
    columns=6,
    rows=7,
    bgcolor=#1e222d,
    border_color=#5b5f6b,
    border_width=1,
    frame_color=#5b5f6b,
    frame_width=1
)

if barstate.isfirst and show_imb_dashboard
    // Hàng tiêu đề — tên các loại imbalance
    if show_fvg
        table.cell(imb_table, 2, 0, "〓 FVG",
            text_color=color.white, text_size=size.small)

    if show_og
        table.cell(imb_table, 3, 0, "◼ OG",
            text_color=color.white, text_size=size.small)

    if show_vi
        table.cell(imb_table, 4, 0, "⬚ VI",
            text_color=color.white, text_size=size.small)

    if show_ob
        table.cell(imb_table, 5, 0, "▣ OB",
            text_color=color.white, text_size=size.small)

    // Merge ô tiêu đề góc
    table.merge_cells(imb_table, 0, 0, 1, 0)

    // Hàng Bullish
    table.cell(imb_table, 0, 1, "Bullish",
        text_color=#00e676, text_size=size.small)

    table.cell(imb_table, 1, 1, "Tần Suất",
        text_color=#00e676, text_size=size.small, text_halign=text.align_left)

    table.cell(imb_table, 1, 2, "Đã Lấp",
        text_color=#00e676, text_size=size.small, text_halign=text.align_left)

    table.merge_cells(imb_table, 0, 1, 0, 2)

    // Hàng Bearish
    table.cell(imb_table, 0, 3, "Bearish",
        text_color=#ff5252, text_size=size.small)

    table.cell(imb_table, 1, 3, "Tần Suất",
        text_color=#ff5252, text_size=size.small, text_halign=text.align_left)

    table.cell(imb_table, 1, 4, "Đã Lấp",
        text_color=#ff5252, text_size=size.small, text_halign=text.align_left)

    table.merge_cells(imb_table, 0, 3, 0, 4)

// ─── Cập nhật dữ liệu bảng imbalance ───
if barstate.islast and show_imb_dashboard
    if show_fvg
        set_imb_cells(imb_table, 2,
            bull_fvg_filled, bull_fvg_count,
            bear_fvg_filled, bear_fvg_count,
            bull_fvg_color, bear_fvg_color, imb_text_size)

    if show_og
        set_imb_cells(imb_table, 3,
            bull_og_filled, bull_og_count,
            bear_og_filled, bear_og_count,
            bull_og_color, bear_og_color, imb_text_size)

    if show_vi
        set_imb_cells(imb_table, 4,
            bull_vi_filled, bull_vi_count,
            bear_vi_filled, bear_vi_count,
            bull_vi_color, bear_vi_color, imb_text_size)

    if show_ob
        set_imb_cells(imb_table, 5,
            ob_bull_mitigated, ob_bull_count,
            ob_bear_mitigated, ob_bear_count,
            ob_bull_color, ob_bear_color, imb_text_size)

// ╔══════════════════════════════════════════╗
// ║              ALERTS                      ║
// ╚══════════════════════════════════════════╝

// ─── FVG Alerts ───
alertcondition(bull_fvg, "Bullish FVG", "Phát hiện Bullish FVG")
alertcondition(bear_fvg, "Bearish FVG", "Phát hiện Bearish FVG")

// ─── OG Alerts ───
alertcondition(bull_og, "Bullish OG", "Phát hiện Bullish OG")
alertcondition(bear_og, "Bearish OG", "Phát hiện Bearish OG")

// ─── VI Alerts ───
alertcondition(bull_vi, "Bullish VI", "Phát hiện Bullish VI")
alertcondition(bear_vi, "Bearish VI", "Phát hiện Bearish VI")

// ─── CHoCH Alerts ───
alertcondition(choch_bull_triggered, "Bullish CHoCH", "Phát hiện Bullish CHoCH - Đảo chiều tăng")
alertcondition(choch_bear_triggered, "Bearish CHoCH", "Phát hiện Bearish CHoCH - Đảo chiều giảm")
